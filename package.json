{
  "name": "remotion-mg",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "remotion studio src/index.ts",
    "dev": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts TextMotion out/video.mp4",
    "typecheck": "tsc --noEmit",
    "gen:manifest": "esbuild scripts/gen-manifest.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/gen-manifest.cjs --loader:.tsx=tsx && node node_modules/.cache/gen-manifest.cjs",
    "gen:thumbnails": "node scripts/gen-thumbnails.mjs",
    "gen:preview": "node scripts/gen-preview-html.mjs",
    "export:theme": "esbuild scripts/export-theme.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/export-theme.cjs && node node_modules/.cache/export-theme.cjs",
    "configurator": "node scripts/export-theme.ts --print",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.240",
    "@remotion/zod-types": "4.0.240",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.240",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/web": "^0.0.139",
    "typescript": "^5.5.4"
  }
}
